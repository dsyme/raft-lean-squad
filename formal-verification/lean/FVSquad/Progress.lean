-- ---------------------------------------------------------------------------
-- PR26: Equivalence of the next_idx guard in `maybeDecrTo`
-- ---------------------------------------------------------------------------

/--
PR26: The Rust guard `next_idx == 0 || next_idx - 1 != rejected` is equivalent
to `next_idx != rejected + 1` over `Nat`.

In Rust this guard prevents underflow on u64; in our `Nat` model the same
condition arises naturally since `Nat.sub` saturates at 0:
  - `next_idx = 0`:  `0 - 1 = 0`, so `0 != rejected` unless `rejected = 0`.
    But the guard is `True` by the first disjunct (`next_idx == 0`), which
    equals `next_idx != rejected + 1` because `rejected + 1 ≥ 1 > 0`.
  - `next_idx > 0`: `next_idx - 1 != rejected` iff `next_idx != rejected + 1`. ✓
-/
theorem PR26_decr_guard_equiv (next_idx rejected : Nat) :
    (next_idx == 0 || next_idx - 1 != rejected) = (next_idx != rejected + 1) := by
  apply Bool.eq_iff_iff.mpr
  simp only [Bool.or_eq_true, beq_iff_eq, bne_iff_ne, ne_eq]
  omega

-- ---------------------------------------------------------------------------
-- PR27–PR28: `maybeDecrTo` in Replicate state
-- ---------------------------------------------------------------------------

/--
PR27: In `Replicate` state, `maybeDecrTo` returns `false` when the rejection is stale
(`rejected < matched` or `rejected = matched` with no snapshot request).
-/
theorem PR27_maybeDecrTo_replicate_stale (p : Progress)
    (rejected match_hint request_snapshot : Nat)
    (hs : p.state = ProgressState.Replicate)
    (hstale : rejected < p.matched ∨
              (rejected = p.matched ∧ request_snapshot = INVALID_INDEX)) :
    (p.maybeDecrTo rejected match_hint request_snapshot).2 = false := by
  simp only [Progress.maybeDecrTo, hs, beq_self_eq_true, ite_true]
  rcases hstale with h | ⟨heq, hrsn⟩
  · simp [h]
  · simp [heq, hrsn, INVALID_INDEX]

/--
PR28: In `Replicate` state, when `rejected > matched`, `maybeDecrTo` with no snapshot
request sets `next_idx = matched + 1` and returns `true`.
-/
theorem PR28_maybeDecrTo_replicate_non_stale_no_snapshot (p : Progress)
    (rejected match_hint : Nat)
    (hs : p.state = ProgressState.Replicate)
    (hgt : p.matched < rejected) :
    (p.maybeDecrTo rejected match_hint INVALID_INDEX).1.next_idx = p.matched + 1 ∧
    (p.maybeDecrTo rejected match_hint INVALID_INDEX).2 = true := by
  have hnlt : ¬(rejected < p.matched) := by omega
  have hne : ¬(rejected = p.matched) := by omega
  simp [Progress.maybeDecrTo, hs, INVALID_INDEX, hnlt, hne]

