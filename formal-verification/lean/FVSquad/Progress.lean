/-!
# Formal Specification: `Progress` — Raft Follower Replication State Machine

Formalises `src/tracker/progress.rs`.

`Progress` tracks how a single Raft follower is catching up with the leader's log.
It is a three-state machine (Probe / Replicate / Snapshot) with an invariant that
`matched + 1 ≤ next_idx`.

This model abstracts away:
- The `Inflights` ring buffer (replaced by a boolean `ins_full : Bool`)
- The `commit_group_id` and `committed_index` fields (not part of the state machine)
- Overflow (all indices modelled as `Nat`)
- The `recent_active` flag (pure metadata, no invariants)

> 🔬 Generated by Lean Squad automated formal verification.
-/

namespace FVSquad.Progress

-- ---------------------------------------------------------------------------
-- Types
-- ---------------------------------------------------------------------------

/-- The three replication states for a follower. -/
inductive ProgressState where
  | Probe    : ProgressState
  | Replicate : ProgressState
  | Snapshot : ProgressState
  deriving DecidableEq, Repr

/-- `INVALID_INDEX` sentinel (matches `src/raft.rs`: `pub const INVALID_INDEX: u64 = 0`). -/
def INVALID_INDEX : Nat := 0

/--
Simplified `Progress` model.  Fields correspond directly to the Rust struct;
`ins_full` abstracts `Inflights::full()`.
-/
structure Progress where
  matched                 : Nat
  next_idx                : Nat
  state                   : ProgressState
  paused                  : Bool
  pending_snapshot        : Nat
  pending_request_snapshot : Nat   -- 0 = INVALID_INDEX
  recent_active           : Bool
  ins_full                : Bool   -- abstraction of Inflights.full()
  deriving Repr

-- ---------------------------------------------------------------------------
-- Well-formedness invariant
-- ---------------------------------------------------------------------------

/-- The core invariant: `matched + 1 ≤ next_idx`. -/
def Progress.wf (p : Progress) : Prop :=
  p.matched + 1 ≤ p.next_idx

-- ---------------------------------------------------------------------------
-- Constructors and helpers
-- ---------------------------------------------------------------------------

/-- `Progress::new(next_idx, ins_size)`.  `ins_full` starts `false`. -/
def Progress.mk_new (next_idx : Nat) : Progress :=
  { matched                  := 0
    next_idx                 := next_idx
    state                    := ProgressState.Probe
    paused                   := false
    pending_snapshot         := 0
    pending_request_snapshot := INVALID_INDEX
    recent_active            := false
    ins_full                 := false }

/-- Internal `reset_state` helper: clears pause and pending_snapshot, sets state. -/
def Progress.resetState (p : Progress) (s : ProgressState) : Progress :=
  { p with paused := false, pending_snapshot := 0, state := s }

-- ---------------------------------------------------------------------------
-- State transitions
-- ---------------------------------------------------------------------------

/-- `Progress::become_probe`. -/
def Progress.becomeProbe (p : Progress) : Progress :=
  if p.state == ProgressState.Snapshot then
    let q := p.resetState ProgressState.Probe
    { q with next_idx := Nat.max (p.matched + 1) (p.pending_snapshot + 1) }
  else
    let q := p.resetState ProgressState.Probe
    { q with next_idx := p.matched + 1 }

/-- `Progress::become_replicate`. -/
def Progress.becomeReplicate (p : Progress) : Progress :=
  let q := p.resetState ProgressState.Replicate
  { q with next_idx := p.matched + 1 }

/-- `Progress::become_snapshot`. -/
def Progress.becomeSnapshot (p : Progress) (snapshot_idx : Nat) : Progress :=
  let q := p.resetState ProgressState.Snapshot
  { q with pending_snapshot := snapshot_idx }

-- ---------------------------------------------------------------------------
-- Mutations
-- ---------------------------------------------------------------------------

/-- `Progress::resume`. -/
def Progress.resume (p : Progress) : Progress := { p with paused := false }

/-- `Progress::pause`. -/
def Progress.pause (p : Progress) : Progress := { p with paused := true }

/--
`Progress::maybe_update(n)`.
Returns `(updated_progress, need_update)`.
Both the matched update and the next_idx advance are modelled faithfully.
-/
def Progress.maybeUpdate (p : Progress) (n : Nat) : Progress × Bool :=
  let need_update := p.matched < n
  let p1 := if need_update then { p with matched := n, paused := false } else p
  let p2 := if p1.next_idx < n + 1 then { p1 with next_idx := n + 1 } else p1
  (p2, need_update)

/-- `Progress::optimistic_update`. -/
def Progress.optimisticUpdate (p : Progress) (n : Nat) : Progress :=
  { p with next_idx := n + 1 }

/-- `Progress::snapshot_failure`. -/
def Progress.snapshotFailure (p : Progress) : Progress :=
  { p with pending_snapshot := 0 }

/-- `Progress::is_paused`. -/
def Progress.isPaused (p : Progress) : Bool :=
  match p.state with
  | ProgressState.Probe     => p.paused
  | ProgressState.Replicate => p.ins_full
  | ProgressState.Snapshot  => true

/-- `Progress::is_snapshot_caught_up`. -/
def Progress.isSnapshotCaughtUp (p : Progress) : Bool :=
  p.state == ProgressState.Snapshot && p.matched >= p.pending_snapshot

/--
`Progress::maybe_decr_to(rejected, match_hint, request_snapshot)`.
Returns `(updated_progress, decremented)`.
In Lean with `Nat`, subtraction saturates at 0; the guard
`next_idx == 0 || next_idx - 1 != rejected` is equivalent to `next_idx != rejected + 1`
over `Nat` (see proof of PR26).
-/
def Progress.maybeDecrTo
    (p : Progress) (rejected match_hint request_snapshot : Nat) : Progress × Bool :=
  if p.state == ProgressState.Replicate then
    -- Stale if rejected ≤ matched (with special case for snapshot request)
    if rejected < p.matched
        || (rejected == p.matched && request_snapshot == INVALID_INDEX) then
      (p, false)
    else if request_snapshot == INVALID_INDEX then
      ({ p with next_idx := p.matched + 1 }, true)
    else
      ({ p with pending_request_snapshot := request_snapshot }, true)
  else
    -- Stale if next_idx - 1 ≠ rejected (and no snapshot request)
    if p.next_idx != rejected + 1 && request_snapshot == INVALID_INDEX then
      (p, false)
    else if request_snapshot == INVALID_INDEX then
      let ni := Nat.min rejected (match_hint + 1)
      let ni' := Nat.max ni (p.matched + 1)
      ({ p with next_idx := ni', paused := false }, true)
    else if p.pending_request_snapshot == INVALID_INDEX then
      ({ p with pending_request_snapshot := request_snapshot, paused := false }, true)
    else
      ({ p with paused := false }, true)

