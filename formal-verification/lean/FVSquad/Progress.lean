-- PR14–PR17: `maybeUpdate` semantics
-- ---------------------------------------------------------------------------

/-- PR14: When `n > matched`, `maybeUpdate` returns `true` and sets `matched = n`. -/
theorem PR14_maybeUpdate_true_updates_matched (p : Progress) (n : Nat)
    (h : p.matched < n) :
    (p.maybeUpdate n).2 = true ∧ (p.maybeUpdate n).1.matched = n := by
  unfold Progress.maybeUpdate
  simp only [h, ite_true]
  by_cases h2 : p.next_idx < n + 1 <;> simp [h2]

/-- PR15: When `n ≤ matched`, `maybeUpdate` returns `false` and leaves `matched` unchanged. -/
theorem PR15_maybeUpdate_false_preserves_matched (p : Progress) (n : Nat)
    (h : ¬(p.matched < n)) :
    (p.maybeUpdate n).2 = false ∧ (p.maybeUpdate n).1.matched = p.matched := by
  unfold Progress.maybeUpdate
  simp only [h, ite_false]
  by_cases h2 : p.next_idx < n + 1 <;> simp [h2]

/-- PR16: `maybeUpdate` always advances `next_idx` to `max(old_next_idx, n + 1)`. -/
theorem PR16_maybeUpdate_next_idx (p : Progress) (n : Nat) :
    (p.maybeUpdate n).1.next_idx = Nat.max p.next_idx (n + 1) := by
  unfold Progress.maybeUpdate
  by_cases h1 : p.matched < n <;> by_cases h2 : p.next_idx < n + 1 <;>
    simp [h1, h2, Nat.max_def] <;> omega

/-- PR17: When `n > matched`, `maybeUpdate` clears `paused` (calls `resume`). -/
theorem PR17_maybeUpdate_resume (p : Progress) (n : Nat)
    (h : p.matched < n) :
    (p.maybeUpdate n).1.paused = false := by
  unfold Progress.maybeUpdate
  simp only [h, ite_true]
  by_cases h2 : p.next_idx < n + 1 <;> simp [h2]

