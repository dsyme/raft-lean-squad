namespace FVSquad.HasNextEntries

/-! ## Core definitions -/

/-- Model of `RaftLog::applied_index_upper_bound`:
    `min(committed, persisted + max_apply_unpersisted_log_limit)`. -/
def appliedIndexUpperBound (committed persisted limit : Nat) : Nat :=
  min committed (persisted + limit)

/-- Model of `RaftLog::has_next_entries_since`.
    `firstIndex` corresponds to `self.first_index()`.
    Returns true iff there is at least one apply-ready entry since `sinceIdx`. -/
def hasNextEntriesSince (firstIndex committed persisted limit sinceIdx : Nat) : Bool :=
  let offset := max (sinceIdx + 1) firstIndex
  let high   := appliedIndexUpperBound committed persisted limit
  high + 1 > offset

/-- Model of `RaftLog::has_next_entries` (calls `has_next_entries_since(self.applied)`). -/
def hasNextEntries (firstIndex committed persisted limit applied : Nat) : Bool :=
  hasNextEntriesSince firstIndex committed persisted limit applied

/-! ## HNE1тАУHNE8: Properties of `appliedIndexUpperBound` -/

/-- **HNE1** тАФ Upper bound never exceeds `committed`. -/
theorem HNE1_upperBound_le_committed (committed persisted limit : Nat) :
    appliedIndexUpperBound committed persisted limit тЙд committed := by
  simp [appliedIndexUpperBound, Nat.min_le_left]

/-- **HNE2** тАФ Upper bound never exceeds `persisted + limit`. -/
theorem HNE2_upperBound_le_persisted_plus (committed persisted limit : Nat) :
    appliedIndexUpperBound committed persisted limit тЙд persisted + limit := by
  simp [appliedIndexUpperBound, Nat.min_le_right]

/-- **HNE3** тАФ When `persisted + limit тЙе committed`, the upper bound equals `committed`. -/
theorem HNE3_upperBound_eq_committed_when_persisted_large
    (committed persisted limit : Nat)
    (h : persisted + limit тЙе committed) :
    appliedIndexUpperBound committed persisted limit = committed := by
  simp [appliedIndexUpperBound, Nat.min_def]; omega

/-- **HNE4** тАФ When `persisted + limit < committed`, the upper bound equals `persisted + limit`. -/
theorem HNE4_upperBound_eq_persisted_plus_when_small
    (committed persisted limit : Nat)
    (h : persisted + limit < committed) :
    appliedIndexUpperBound committed persisted limit = persisted + limit := by
  simp [appliedIndexUpperBound, Nat.min_def]; omega

/-- **HNE5** тАФ Upper bound is monotone in `committed`. -/
theorem HNE5_upperBound_mono_committed
    (c1 c2 persisted limit : Nat) (hle : c1 тЙд c2) :
    appliedIndexUpperBound c1 persisted limit тЙд appliedIndexUpperBound c2 persisted limit := by
  simp only [appliedIndexUpperBound, Nat.min_def]
  split <;> split <;> omega

/-- **HNE6** тАФ Upper bound is monotone in `persisted`. -/
theorem HNE6_upperBound_mono_persisted
    (committed p1 p2 limit : Nat) (hle : p1 тЙд p2) :
    appliedIndexUpperBound committed p1 limit тЙд appliedIndexUpperBound committed p2 limit := by
  simp only [appliedIndexUpperBound, Nat.min_def]
  split <;> split <;> omega

/-- **HNE7** тАФ Upper bound is monotone in `limit`. -/
theorem HNE7_upperBound_mono_limit
    (committed persisted l1 l2 : Nat) (hle : l1 тЙд l2) :
    appliedIndexUpperBound committed persisted l1 тЙд appliedIndexUpperBound committed persisted l2 := by
  simp only [appliedIndexUpperBound, Nat.min_def]
  split <;> split <;> omega

/-- **HNE8** тАФ With `limit = 0`, upper bound equals `min(committed, persisted)`. -/
theorem HNE8_upperBound_zero_limit_eq_min
    (committed persisted : Nat) :
    appliedIndexUpperBound committed persisted 0 = min committed persisted := by
  simp [appliedIndexUpperBound]

/-! ## HNE9тАУHNE13: Properties of `hasNextEntriesSince` -/

/-- **HNE9** тАФ Biconditional: `hasNextEntriesSince` returns `true` iff
    `max(sinceIdx + 1, firstIndex) тЙд appliedIndexUpperBound`. -/
theorem HNE9_hasNextEntriesSince_true_iff
    (firstIndex committed persisted limit sinceIdx : Nat) :
    hasNextEntriesSince firstIndex committed persisted limit sinceIdx = true тЖФ
    max (sinceIdx + 1) firstIndex тЙд appliedIndexUpperBound committed persisted limit := by
  simp [hasNextEntriesSince]
  omega

/-- **HNE10** тАФ If `sinceIdx тЙе appliedIndexUpperBound`, returns `false`. -/
theorem HNE10_hasNextEntriesSince_false_of_ge_bound
    (firstIndex committed persisted limit sinceIdx : Nat)
    (h : sinceIdx тЙе appliedIndexUpperBound committed persisted limit) :
    hasNextEntriesSince firstIndex committed persisted limit sinceIdx = false := by
  simp [hasNextEntriesSince, Nat.not_lt]
  omega

/-- **HNE11** тАФ Anti-monotone in `sinceIdx`: smaller `sinceIdx` тЗТ at least as likely to be `true`. -/
theorem HNE11_hasNextEntriesSince_anti_mono_since
    (firstIndex committed persisted limit j k : Nat)
    (hjk : j тЙд k)
    (htrue : hasNextEntriesSince firstIndex committed persisted limit k = true) :
    hasNextEntriesSince firstIndex committed persisted limit j = true := by
  simp [hasNextEntriesSince] at *
  omega

/-- **HNE12** тАФ Monotone in `committed`: if true for `c1`, then true for any `c2 тЙе c1`. -/
theorem HNE12_hasNextEntriesSince_mono_committed
    (firstIndex c1 c2 persisted limit sinceIdx : Nat)
    (hle : c1 тЙд c2)
    (htrue : hasNextEntriesSince firstIndex c1 persisted limit sinceIdx = true) :
    hasNextEntriesSince firstIndex c2 persisted limit sinceIdx = true := by
  simp [hasNextEntriesSince, appliedIndexUpperBound] at *
  omega

/-- **HNE13** тАФ Monotone in `persisted`: if true for `p1`, then true for any `p2 тЙе p1`. -/
theorem HNE13_hasNextEntriesSince_mono_persisted
    (firstIndex committed p1 p2 limit sinceIdx : Nat)
    (hle : p1 тЙд p2)
    (htrue : hasNextEntriesSince firstIndex committed p1 limit sinceIdx = true) :
    hasNextEntriesSince firstIndex committed p2 limit sinceIdx = true := by
  simp [hasNextEntriesSince, appliedIndexUpperBound] at *
  omega

/-! ## HNE14: Connection between `hasNextEntries` and `hasNextEntriesSince` -/

/-- **HNE14** тАФ `hasNextEntries` equals `hasNextEntriesSince applied`. -/
theorem HNE14_hasNextEntries_eq_since_applied
    (firstIndex committed persisted limit applied : Nat) :
    hasNextEntries firstIndex committed persisted limit applied =
    hasNextEntriesSince firstIndex committed persisted limit applied :=
  rfl

