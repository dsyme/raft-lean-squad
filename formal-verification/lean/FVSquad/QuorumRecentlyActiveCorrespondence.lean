namespace FVSquad.QuorumRecentlyActiveCorrespondence

open FVSquad.QuorumRecentlyActive
open FVSquad.Progress

/-! ## Helper: construct a `Progress` value with a given `recent_active` flag -/

/-- Build a minimal `Progress` value for correspondence tests.
    Only `recent_active` varies; all other fields use their default values. -/
private def mkPr (ra : Bool) : Progress :=
  { matched := 0, next_idx := 1, state := .Probe, paused := false,
    pending_snapshot := 0, pending_request_snapshot := 0,
    recent_active := ra, ins_full := false }

/-! ## Case 1: Empty voters → always true (vacuous majority) -/

#guard quorumRecentlyActive [] [] 1 == true

/-! ## Case 2: Single voter = perspectiveOf, has entry → true
    Leader always counts itself when it has a progress entry.
    `isActive [(1,F)] 1 1 = true` (because `1 == perspectiveOf = 1`).
    overlap([1], 1 active) = 1 ≥ majority(1) = 1 → true. -/

#guard quorumRecentlyActive [1] [(1, mkPr false)] 1 == true

/-! ## Case 3: Single voter = perspectiveOf, NOT in entries → false
    `isActive [] 1 1 = false` (no entries).
    overlap([1], 0 active) = 0 < majority(1) = 1 → false. -/

#guard quorumRecentlyActive [1] [] 1 == false

/-! ## Case 4: 3 voters; leader + one recently-active follower → true
    voters = [1,2,3], perspectiveOf = 1.
    Active: {1 (leader), 2 (recent_active=T)}. Inactive: {3}.
    overlap = 2 ≥ majority(3) = 2 → true. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr false), (2, mkPr true), (3, mkPr false)] 1 == true

/-! ## Case 5: 3 voters; only leader active → false
    voters = [1,2,3], perspectiveOf = 1.
    Active: {1}. All others have recent_active = false.
    overlap = 1 < majority(3) = 2 → false. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr false), (2, mkPr false), (3, mkPr false)] 1 == false

/-! ## Case 6: Leader NOT in entries; two followers active → true
    voters = [1,2,3], perspectiveOf = 1 (not in entries).
    Active: {2, 3} (recent_active = true). Leader 1 not counted.
    overlap = 2 ≥ majority(3) = 2 → true.
    Demonstrates that leader-not-in-entries still allows quorum from followers. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(2, mkPr true), (3, mkPr true)] 1 == true

/-! ## Case 7: All three entries have recent_active = true → true -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr true), (2, mkPr true), (3, mkPr true)] 1 == true

/-! ## Case 8: No entries at all → false
    No node is active (not even the leader). overlap = 0 < 2 → false. -/

#guard quorumRecentlyActive [1, 2, 3] [] 1 == false

/-! ## Case 9: 5 voters; leader + 2 followers active = majority → true
    Active: {1, 2, 3}. overlap = 3 = majority(5) = 3 → true. -/

#guard quorumRecentlyActive [1, 2, 3, 4, 5]
  [(1, mkPr false), (2, mkPr true), (3, mkPr true),
   (4, mkPr false), (5, mkPr false)] 1 == true

/-! ## Case 10: 5 voters; leader + 1 follower active → false
    Active: {1, 2}. overlap = 2 < majority(5) = 3 → false. -/

#guard quorumRecentlyActive [1, 2, 3, 4, 5]
  [(1, mkPr false), (2, mkPr true), (3, mkPr false),
   (4, mkPr false), (5, mkPr false)] 1 == false

/-! ## Case 11: 5 voters; only leader active → false
    Active: {1}. overlap = 1 < majority(5) = 3 → false. -/

#guard quorumRecentlyActive [1, 2, 3, 4, 5]
  [(1, mkPr false)] 1 == false

/-! ## Case 12: perspectiveOf = 2; follower 3 active → true
    voters = [1,2,3], perspectiveOf = 2.
    Active: {2 (leader), 3 (recent_active=T)}. Inactive: {1}.
    overlap = 2 ≥ majority(3) = 2 → true. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr false), (2, mkPr false), (3, mkPr true)] 2 == true

/-! ## Case 13: perspectiveOf = 2; follower 1 active → true
    voters = [1,2,3], perspectiveOf = 2.
    Active: {1 (recent_active=T), 2 (leader)}. Inactive: {3}.
    overlap = 2 ≥ majority(3) = 2 → true. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr true), (2, mkPr false), (3, mkPr false)] 2 == true

/-! ## Case 14: perspectiveOf = 2; all recent_active = false → false
    voters = [1,2,3], perspectiveOf = 2.
    Active: {2 (leader only)}. overlap = 1 < 2 → false. -/

#guard quorumRecentlyActive [1, 2, 3]
  [(1, mkPr false), (2, mkPr false), (3, mkPr false)] 2 == false

end FVSquad.QuorumRecentlyActiveCorrespondence
