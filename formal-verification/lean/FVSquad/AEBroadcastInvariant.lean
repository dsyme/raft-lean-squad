section Examples

/-- Example: sanity check that ABI1 applies to a trivial 1-voter setup. -/
example (E : Type) [DecidableEq E]
    {cs cs' : ClusterState E} {lead v : Nat} {msg : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs lead v msg cs')
    (hprev0 : msg.prevLogIndex = 0)
    (hlead_ne : lead ≠ v) :
    cs'.logs v 1 = cs'.logs lead 1 :=
  hae_for_voter_after_ae E hstep hprev0 hlead_ne 1 (Nat.le_refl _)

/-- Example: two-step broadcast, both voters covered. -/
example (E : Type) [DecidableEq E]
    {cs1 cs2 cs3 : ClusterState E} {lead v1 v2 : Nat}
    {msg1 msg2 : AppendEntriesMsg E}
    (hstep1 : ValidAEStep E cs1 lead v1 msg1 cs2)
    (hstep2 : ValidAEStep E cs2 lead v2 msg2 cs3)
    (h0_1 : msg1.prevLogIndex = 0) (h0_2 : msg2.prevLogIndex = 0)
    (hne1 : lead ≠ v1) (hne2 : lead ≠ v2)
    (voterIdx : Nat → Nat) (hb1 : 1 ≤ voterIdx v1) (hb2 : 1 ≤ voterIdx v2) :
    HaeCovered E [v2, v1] cs3.logs lead voterIdx :=
  haeCovered_extend E hstep2 h0_2 hne2 voterIdx hb2 [v1]
    (haeCovered_extend E hstep1 h0_1 hne1 voterIdx hb1 []
      (haeCovered_nil E cs1.logs lead voterIdx))

end Examples

