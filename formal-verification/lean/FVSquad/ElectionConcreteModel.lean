-- ECM1: CandLogCoversLastIndex from hae
-- ═══════════════════════════════════════════════════════════

/-- **ECM1** — `CandLogCoversLastIndex` follows from the log-agreement hypothesis `hae`.

    `hae` states: for every voter `w` and every index `k ≤ (voterLog w).index`,
    voter `w`'s log agrees with the candidate's log: `logs w k = candLog k`.

    **Proof**: Apply ER9 (`candLogCoversLastIndex_of_sharedSource`) with `R = candLog`.
    Condition (a) is trivial (`candLog = candLog`).
    Condition (b) follows from `hae w (voterLog w).index (le_refl _)`.

    **Significance**: This is the simplest path to `CandLogCoversLastIndex` in a concrete
    model.  The shared-source proof via ER9 avoids needing an explicit high-water-mark
    witness for each voter. -/
theorem candLogCoversLastIndex_of_hae (E : Type)
    (voterLog : Nat → LogId) (logs : VoterLogs E) (candLog : Nat → Option E)
    (hae : ∀ w k, k ≤ (voterLog w).index → logs w k = candLog k) :
    CandLogCoversLastIndex E voterLog logs candLog :=
  candLogCoversLastIndex_of_sharedSource E voterLog logs candLog candLog
    (fun _ => rfl)
    (fun w => (hae w (voterLog w).index (Nat.le_refl _)).symm)

-- ═══════════════════════════════════════════════════════════
-- ECM2: CandLogMatching from hae
-- ═══════════════════════════════════════════════════════════

/-- **ECM2** — `CandLogMatching` follows from the log-agreement hypothesis `hae`, together
    with the bounded-log assumption `hlog_none` (voters have no entries beyond their last
    index) and `hcand_mono` (the candidate's log is downward-closed: `none` propagates left).

    **Proof**: Directly applies CT5 (`candLogMatching_of_broadcast`) from
    `ConcreteTransitions.lean`. -/
theorem candLogMatching_of_hae (E : Type)
    (voterLog : Nat → LogId) (logs : VoterLogs E) (candLog : Nat → Option E)
    (hae      : ∀ w k, k ≤ (voterLog w).index → logs w k = candLog k)
    (hlog_none : ∀ w k, k > (voterLog w).index → logs w k = none)
    (hcand_mono : ∀ j k, j ≤ k → candLog k = none → candLog j = none) :
    CandLogMatching E logs candLog :=
  candLogMatching_of_broadcast E voterLog logs candLog hae hlog_none hcand_mono

-- ═══════════════════════════════════════════════════════════
-- ECM3: CandidateLogCovers from hae
-- ═══════════════════════════════════════════════════════════

/-- **ECM3** — `CandidateLogCovers` for the elected leader follows from the
    log-agreement hypothesis `hae`.

    Combines ECM1 (CandLogCoversLastIndex from hae) and ECM2 (CandLogMatching from hae)
    via ER10 (`candidateLogCovers_of_sharedSource`).

    **Preconditions**:
    - `hae`       : voter logs agree with leader's log up to each voter's last index
    - `hlog_none` : voters have no entries beyond their last index
    - `hcand_mono`: leader's log is downward-closed (no gaps)
    - `hconsist`  : vote record is consistent (all recorded votes came from `voteGranted`)
    - `hvoter_idx`: voter `w`'s log only has entries at indices ≤ `(voterLog w).index` -/
theorem candidateLogCovers_of_hae (E : Type)
    (hd : Nat) (tl : List Nat) (record : VoteRecord)
    (voterLog : Nat → LogId)
    (candLastTerm candLastIndex : Nat → Nat)
    (logs : VoterLogs E) (candLog : Nat → Option E) (term cand : Nat)
    (hae       : ∀ w k, k ≤ (voterLog w).index → logs w k = candLog k)
    (hlog_none : ∀ w k, k > (voterLog w).index → logs w k = none)
    (hcand_mono : ∀ j k, j ≤ k → candLog k = none → candLog j = none)
    (hconsist  : VoteRecordConsistency record voterLog candLastTerm candLastIndex)
    (hvoter_idx : ∀ w k e, w ∈ (hd :: tl) → logs w k = some e → k ≤ (voterLog w).index) :
    CandidateLogCovers E (hd :: tl) record term cand logs candLog :=
  candidateLogCovers_of_sharedSource E hd tl record voterLog candLastTerm candLastIndex
    logs candLog term cand candLog
    (candLogMatching_of_hae E voterLog logs candLog hae hlog_none hcand_mono)
    (fun _ => rfl)
    (fun w => (hae w (voterLog w).index (Nat.le_refl _)).symm)
    hconsist
    hvoter_idx

-- ═══════════════════════════════════════════════════════════
-- ECM4: hqc_preserved from hae + ValidAEStep
-- ═══════════════════════════════════════════════════════════

/-- **ECM4** — `hqc_preserved` holds in a concrete Raft step given the log-agreement
    hypothesis `hae`.

    Combines ECM3 (`candidateLogCovers_of_hae`) with CPS13
    (`validAEStep_hqc_preserved_from_lc`) to discharge the `hqc_preserved` hypothesis
    in `RaftReachable.step`.

    **Interpretation**: after a valid AppendEntries step from the elected leader `lead`
    to voter `v`, if (a) the leader won the election, (b) voters' logs agree with the
    leader's up to their last accepted index, and (c) the vote record is consistent,
    then quorum-committed entries remain quorum-committed in the new cluster state. -/
theorem hqc_preserved_of_hae [DecidableEq E]
    {cs cs' : ClusterState E} {lead v : Nat} {msg : AppendEntriesMsg E}
    (hstep  : ValidAEStep E cs lead v msg cs')
    (hd     : Nat) (tl : List Nat)
    (hvoters : cs.voters = hd :: tl)
    (record : VoteRecord) (term : Nat)
    (voterLog : Nat → LogId)
    (candLastTerm candLastIndex : Nat → Nat)
    (hwin      : wonInTerm (hd :: tl) record term lead = true)
    (hae       : ∀ w k, k ≤ (voterLog w).index → cs.logs w k = cs.logs lead k)
    (hlog_none : ∀ w k, k > (voterLog w).index → cs.logs w k = none)
    (hcand_mono : ∀ j k, j ≤ k → cs.logs lead k = none → cs.logs lead j = none)
    (hconsist  : VoteRecordConsistency record voterLog candLastTerm candLastIndex)
    (hvoter_idx : ∀ w k e, w ∈ (hd :: tl) → cs.logs w k = some e → k ≤ (voterLog w).index) :
    ∀ k e, isQuorumCommitted cs.voters cs.logs k e →
           isQuorumCommitted cs'.voters cs'.logs k e :=
  validAEStep_hqc_preserved_from_lc hstep hd tl hvoters record term hwin
    (candidateLogCovers_of_hae E hd tl record voterLog candLastTerm candLastIndex
      cs.logs (cs.logs lead) term lead
      hae hlog_none hcand_mono hconsist hvoter_idx)

-- ═══════════════════════════════════════════════════════════
-- ECM5: Single AE step gives partial hae for the new voter
-- ═══════════════════════════════════════════════════════════

/-- **ECM5** — After a single valid AppendEntries step from `lead` to voter `v`,
    the voter's updated log agrees with the leader's at the AE-covered indices.

    Specifically, for every index `k > msg.prevLogIndex`:
    `cs'.logs v k = cs.logs lead k`.

    This is a direct consequence of `hcand_eq` from `ValidAEStep` combined with
    `hlogs'_v` and `applyAE_extends_at_entries`. -/
theorem hae_of_validAEStep (E : Type) [DecidableEq E]
    {cs cs' : ClusterState E} {lead v : Nat} {msg : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs lead v msg cs')
    (k : Nat) (hk : k > msg.prevLogIndex) :
    cs'.logs v k = cs.logs lead k := by
  rw [congrFun hstep.hlogs'_v k]
  exact hstep.hcand_eq k hk

/-- **ECM5b** — After a valid AE step, the AE does not change other voters' logs.
    `cs'.logs w k = cs.logs w k` for any voter `w ≠ v`. -/
theorem hae_other_of_validAEStep (E : Type) [DecidableEq E]
    {cs cs' : ClusterState E} {lead v : Nat} {msg : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs lead v msg cs')
    (w : Nat) (hw : w ≠ v) (k : Nat) :
    cs'.logs w k = cs.logs w k :=
  congrFun (hstep.hlogs'_other w hw) k

-- ═══════════════════════════════════════════════════════════
-- ECM6: Composition — hqc_preserved directly from AE step + hae
-- ═══════════════════════════════════════════════════════════

/-- **ECM6** — Full composition theorem:

    Given a concrete cluster state `cs` where:
    1. The leader `lead` won the election (`hwin`)
    2. Voters' logs agree with the leader's up to their last index (`hae`)
    3. Vote record is consistent (`hconsist`)
    4. A valid AppendEntries step `hstep` is applied

    Then `hqc_preserved` holds: quorum-certified entries survive the AE step.

    This is the primary export of this file — the complete bridge from a concrete
    election model to the `hqc_preserved` hypothesis required by `RaftReachable.step`.

    **Modelling notes**:
    - `hae` captures the post-broadcast agreement; in a real protocol this is derived by
      induction over AE steps (each step extends the agreement region).
    - `hlog_none` and `hcand_mono` are well-formedness assumptions on the log model.
    - The `voterLog` function maps each voter to their last accepted `LogId`; this is
      implicit in the concrete Rust implementation (tracked via `nextIndex` / `matchIndex`). -/
theorem hqc_preserved_of_validAEStep [DecidableEq E]
    {cs cs' : ClusterState E} {lead v : Nat} {msg : AppendEntriesMsg E}
    (hstep  : ValidAEStep E cs lead v msg cs')
    (hd     : Nat) (tl : List Nat)
    (hvoters : cs.voters = hd :: tl)
    (record : VoteRecord) (term : Nat)
    (voterLog : Nat → LogId)
    (candLastTerm candLastIndex : Nat → Nat)
    (hwin      : wonInTerm (hd :: tl) record term lead = true)
    (hae       : ∀ w k, k ≤ (voterLog w).index → cs.logs w k = cs.logs lead k)
    (hlog_none : ∀ w k, k > (voterLog w).index → cs.logs w k = none)
    (hcand_mono : ∀ j k, j ≤ k → cs.logs lead k = none → cs.logs lead j = none)
    (hconsist  : VoteRecordConsistency record voterLog candLastTerm candLastIndex)
    (hvoter_idx : ∀ w k e, w ∈ (hd :: tl) → cs.logs w k = some e → k ≤ (voterLog w).index) :
    ∀ k e, isQuorumCommitted cs.voters cs.logs k e →
           isQuorumCommitted cs'.voters cs'.logs k e :=
  hqc_preserved_of_hae hstep hd tl hvoters record term voterLog candLastTerm candLastIndex
    hwin hae hlog_none hcand_mono hconsist hvoter_idx

-- ═══════════════════════════════════════════════════════════
-- ECM7: The shared-source witness is explicit
-- ═══════════════════════════════════════════════════════════

/-- **ECM7** — For documentation: makes the shared-source reference log `R = candLog`
    explicit.  When `hae` holds, the leader's own log serves as the shared reference log
    and trivially satisfies both sides of the ER9 condition.

    This theorem is a transparent re-statement of ECM1, making the shared-source
    reference `R = candLog` visible in the statement for the CORRESPONDENCE.md audit. -/
theorem sharedSource_of_hae (E : Type)
    (voterLog : Nat → LogId) (logs : VoterLogs E) (candLog : Nat → Option E)
    (hae : ∀ w k, k ≤ (voterLog w).index → logs w k = candLog k) :
    ∃ R : Nat → Option E,
      (∀ w, R (voterLog w).index = candLog (voterLog w).index) ∧
      (∀ w, R (voterLog w).index = logs w (voterLog w).index) :=
  ⟨candLog, fun _ => rfl, fun w => (hae w (voterLog w).index (Nat.le_refl _)).symm⟩

