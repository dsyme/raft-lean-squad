/-- RA1: Empty batch is a no-op; returns the unchanged log and current last_index.
    Postcondition P1 from the informal spec. -/
theorem ra1_empty_noop (rl : RaftLog) :
    raftLogAppend rl [] = (rl, raftLastIndex rl) := by
  simp [raftLogAppend]

/-- RA2: The returned index is always the new `raftLastIndex`.
    Postcondition P2 from the informal spec. -/
theorem ra2_return_is_lastIndex (rl : RaftLog) (ents : List Entry) :
    (raftLogAppend rl ents).2 = raftLastIndex (raftLogAppend rl ents).1 := by
  cases ents with
  | nil => simp [raftLogAppend]
  | cons e rest => simp [raftLogAppend]

/-- RA3: Non-empty batch with no-gap precondition: the returned index equals
    `first.index + (first :: rest).length - 1`.
    This is the last entry's index assuming entries are consecutive.
    (Postcondition P3 from the informal spec.)
    `hle` ensures no gap is created (normal Raft no-gap invariant). -/
theorem ra3_return_lastEntry (rl : RaftLog) (first : Entry) (rest : List Entry)
    (hle : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length) :
    (raftLogAppend rl (first :: rest)).2 = first.1 + (first :: rest).length - 1 := by
  simp only [raftLogAppend, List.length_cons, raftLastIndex]
  have hne : (first :: rest).map (·.2) ≠ [] := by simp
  rw [taa_maybeLastIndex rl.unstable ((first :: rest).map (·.2)) first.1 hne (by simpa using hle)]
  simp [List.length_map]

/-- RA4: `committed` is never modified by `raftLogAppend`.
    Invariant I1 (partial) / Postcondition P8 from the informal spec. -/
theorem ra4_committed_unchanged (rl : RaftLog) (ents : List Entry) :
    (raftLogAppend rl ents).1.committed = rl.committed := by
  cases ents with
  | nil  => simp [raftLogAppend]
  | cons => simp [raftLogAppend]

/-- RA5: `stableLastIdx` is never modified by `raftLogAppend`. -/
theorem ra5_stableLastIdx_unchanged (rl : RaftLog) (ents : List Entry) :
    (raftLogAppend rl ents).1.stableLastIdx = rl.stableLastIdx := by
  cases ents with
  | nil  => simp [raftLogAppend]
  | cons => simp [raftLogAppend]

/-- RA6: The pending snapshot is preserved (not affected by appending entries).
    Uses `truncateAndAppend_snapshot_preserved` from LogUnstable. -/
theorem ra6_snapshot_preserved (rl : RaftLog) (ents : List Entry) :
    (raftLogAppend rl ents).1.unstable.snapshot = rl.unstable.snapshot := by
  cases ents with
  | nil  => simp [raftLogAppend]
  | cons e rest =>
    simp only [raftLogAppend]
    exact truncateAndAppend_snapshot_preserved rl.unstable ((e :: rest).map (·.2)) e.1

/-- RA7: Safety guard — if the batch starts strictly after `committed` (the Rust panic guard),
    then `committed` is strictly less than the returned last index.
    Preconditions mirror the Rust: `hguard` (non-overwrite of committed) and `hle` (no gap).
    Proves the structural invariant enforced by `fatal!` in `src/raft_log.rs:393`. -/
theorem ra7_committed_below_return (rl : RaftLog) (first : Entry) (rest : List Entry)
    (hguard : rl.committed < first.1)
    (hle : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length) :
    rl.committed < (raftLogAppend rl (first :: rest)).2 := by
  rw [ra3_return_lastEntry rl first rest hle]
  simp [List.length_cons]
  omega

/-- RA8: When the batch is empty, raftLastIndex is unchanged. -/
theorem ra8_empty_lastIndex_stable (rl : RaftLog) :
    (raftLogAppend rl []).2 = raftLastIndex rl := by
  simp [raftLogAppend]

/-- RA9 (Summary composition): For a non-empty no-gap batch,
    the returned index matches `first.index + batch.length - 1`.
    For consecutive entries this equals the last entry's index.
    This is a named alias for RA3. -/
theorem ra9_return_is_batch_last
    (rl : RaftLog)
    (first : Entry) (rest : List Entry)
    (hle : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length) :
    (raftLogAppend rl (first :: rest)).2 = first.1 + (first :: rest).length - 1 :=
  ra3_return_lastEntry rl first rest hle

