/-- Helper: `truncateAndAppend` offset never exceeds `after`. -/
private theorem taa_offset_le_after (u : Unstable) (newTerms : List Nat) (after : Nat) :
    (truncateAndAppend u newTerms after).offset ≤ after := by
  by_cases h1 : after = u.offset + u.entries.length
  · rw [truncateAndAppend_case1_offset u newTerms after h1]; omega
  · by_cases h2 : after ≤ u.offset
    · obtain ⟨hO, _⟩ := truncateAndAppend_case2 u newTerms after h1 h2; simp [hO]
    · have hO : (truncateAndAppend u newTerms after).offset = u.offset := by
        simp only [truncateAndAppend, if_neg h1, if_neg h2]
      rw [hO]; omega

/-- Helper: the total extent (offset + length) of `truncateAndAppend` equals
    `after + newTerms.length` in all three cases. -/
private theorem taa_total_extent (u : Unstable) (newTerms : List Nat) (after : Nat)
    (hle : after ≤ u.offset + u.entries.length) :
    (truncateAndAppend u newTerms after).offset +
    (truncateAndAppend u newTerms after).entries.length = after + newTerms.length := by
  by_cases h1 : after = u.offset + u.entries.length
  · rw [truncateAndAppend_case1_offset u newTerms after h1,
        truncateAndAppend_case1_length u newTerms after h1]
    omega
  · by_cases h2 : after ≤ u.offset
    · obtain ⟨hO, hE⟩ := truncateAndAppend_case2 u newTerms after h1 h2
      simp [hO, hE]
    · have hO : (truncateAndAppend u newTerms after).offset = u.offset := by
        simp only [truncateAndAppend, if_neg h1, if_neg h2]
      -- truncateAndAppend_case3_length gives: entries.length = (after - u.offset) + newTerms.length
      rw [hO, truncateAndAppend_case3_length u newTerms after h1 h2 (by omega)]
      omega

/-- Helper: `truncateAndAppend` places new terms at the expected positions.
    For `after ≤ k < after + newTerms.length`, the `maybeTerm` equals `newTerms[k - after]?`. -/
private theorem taa_maybeTerm_at_batch (u : Unstable) (newTerms : List Nat) (after : Nat)
    (k : Nat) (hk1 : after ≤ k) (hk2 : k < after + newTerms.length)
    (hle : after ≤ u.offset + u.entries.length) :
    maybeTerm (truncateAndAppend u newTerms after) k = newTerms[k - after]? := by
  by_cases h1 : after = u.offset + u.entries.length
  · have hE := truncateAndAppend_case1 u newTerms after h1
    have hO := truncateAndAppend_case1_offset u newTerms after h1
    simp only [maybeTerm, hO, if_neg (by omega : ¬k < u.offset), hE]
    rw [List.getElem?_append_right (by omega : u.entries.length ≤ k - u.offset)]
    congr 1; omega
  · by_cases h2 : after ≤ u.offset
    · obtain ⟨hO, hE⟩ := truncateAndAppend_case2 u newTerms after h1 h2
      simp only [maybeTerm, hO, if_neg (by omega : ¬k < after), hE]
    · have hO : (truncateAndAppend u newTerms after).offset = u.offset := by
        simp only [truncateAndAppend, if_neg h1, if_neg h2]
      have hE := truncateAndAppend_case3 u newTerms after h1 h2
      simp only [maybeTerm, hO, if_neg (by omega : ¬k < u.offset), hE]
      rw [List.getElem?_append_right
            (by rw [List.length_take, Nat.min_eq_left (by omega)]; omega)]
      congr 1
      rw [List.length_take, Nat.min_eq_left (by omega)]; omega

/-- **P6 (RA-BATCH)** — Postcondition: batch entries are placed at the expected positions.

    After `raftLogAppend rl (first :: rest)`, for index `k` in the batch range
    `[first.1, first.1 + batch.length)`, the unstable term equals the entry's term.

    This closes the "batch suffix matches" postcondition (P6) from the informal spec.

    **Proof**: reduces to `taa_maybeTerm_at_batch` on the inner `truncateAndAppend`.
    🔬 Generated by Lean Squad automated formal verification (Run 50). -/
theorem ra_batch_term (rl : RaftLog) (first : Entry) (rest : List Entry)
    (k : Nat)
    (hk1 : first.1 ≤ k) (hk2 : k < first.1 + (first :: rest).length)
    (hle : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length) :
    maybeTerm (raftLogAppend rl (first :: rest)).1.unstable k =
    ((first :: rest).map (·.2))[k - first.1]? := by
  simp only [raftLogAppend]
  exact taa_maybeTerm_at_batch rl.unstable ((first :: rest).map (·.2)) first.1 k
    hk1 (by simpa [List.length_map] using hk2) (by simpa using hle)

/-- **P7 (RA-BEYOND)** — Postcondition: entries beyond the batch are discarded.

    After `raftLogAppend rl (first :: rest)`, for index `k ≥ first.1 + batch.length`,
    the unstable term is `none` — the truncation removes any prior unstable content there.

    This closes the "beyond-batch discarded" postcondition (P7) from the informal spec.

    **Proof**: `taa_total_extent` gives offset + length = after + terms.length ≤ k,
    then `maybeTerm_entries_miss` (MT5) yields `none`.
    🔬 Generated by Lean Squad automated formal verification (Run 50). -/
theorem ra_beyond_batch_none (rl : RaftLog) (first : Entry) (rest : List Entry)
    (k : Nat) (hk : first.1 + (first :: rest).length ≤ k)
    (hle : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length) :
    maybeTerm (raftLogAppend rl (first :: rest)).1.unstable k = none := by
  simp only [raftLogAppend]
  have hle' : first.1 ≤ rl.unstable.offset + rl.unstable.entries.length := by simpa using hle
  have hext := taa_total_extent rl.unstable ((first :: rest).map (·.2)) first.1
    (by simpa using hle)
  have hoffset := taa_offset_le_after rl.unstable ((first :: rest).map (·.2)) first.1
  simp only [List.length_map] at hext hk
  apply maybeTerm_entries_miss
  · omega
  · omega

