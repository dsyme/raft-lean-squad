-- Data structures
-- ═══════════════════════════════════════════════════════════

/-- Abstract model of the Raft log combining stable and unstable segments.
    Corresponds to `struct RaftLog<T>` in `src/raft_log.rs`. -/
structure RaftLog where
  /-- Highest committed log index (monotone, never decreases). -/
  committed     : Nat
  /-- Last index in stable storage — read-only in `append`. -/
  stableLastIdx : Nat
  /-- Unstable (not-yet-persisted) log segment. -/
  unstable      : Unstable
  deriving Repr

/-- A log entry: (log-index, term).  Payload omitted from this model. -/
abbrev Entry := Nat × Nat

-- ═══════════════════════════════════════════════════════════
-- Core functions
-- ═══════════════════════════════════════════════════════════

/-- Overall last log index: unstable segment's last index if non-empty,
    otherwise the stable storage's last index.
    Models `RaftLog::last_index`. -/
def raftLastIndex (rl : RaftLog) : Nat :=
  (maybeLastIndex rl.unstable).getD rl.stableLastIdx

/-- Append a batch of entries to the raft log.
    Preconditions (success path, panic not modelled):
      • `ents` non-empty → `ents[0].1 > rl.committed`   (P4 safety guard)
      • `ents[0].1 ≤ rl.unstable.offset + rl.unstable.entries.length` (no-gap; normal Raft invariant)
    Returns `(updated_log, new_last_index)`.
    Models `RaftLog::append`. -/
def raftLogAppend (rl : RaftLog) (ents : List Entry) : RaftLog × Nat :=
  match ents with
  | []    => (rl, raftLastIndex rl)
  | e :: _ =>
    let after    := e.1                      -- ents[0].index
    let newTerms := ents.map (·.2)           -- extract terms
    let newU     := truncateAndAppend rl.unstable newTerms after
    let newRl    := { rl with unstable := newU }
    (newRl, raftLastIndex newRl)

