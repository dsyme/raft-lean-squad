-- Helper: truncateAndAppend with non-empty newTerms
-- ═══════════════════════════════════════════════════════════

/-- HTAA1: truncateAndAppend produces non-empty entries when newTerms is non-empty. -/
theorem taa_entries_nonempty (u : Unstable) (newTerms : List Nat) (after : Nat)
    (hne : newTerms ≠ []) :
    (truncateAndAppend u newTerms after).entries ≠ [] := by
  unfold truncateAndAppend
  by_cases h1 : after = u.offset + u.entries.length
  · rw [if_pos h1]
    cases newTerms with
    | nil  => exact absurd rfl hne
    | cons => simp
  · rw [if_neg h1]
    by_cases h2 : after ≤ u.offset
    · rw [if_pos h2]; exact hne
    · rw [if_neg h2]
      cases newTerms with
      | nil  => exact absurd rfl hne
      | cons => simp

/-- HTAA2: maybeLastIndex after truncateAndAppend with non-empty newTerms and no-gap precondition.
    Key lemma: the new last index is `after + newTerms.length - 1`.
    Precondition `hle`: the batch starts at or before the next available slot
    (i.e., no gap is introduced in the log). -/
theorem taa_maybeLastIndex (u : Unstable) (newTerms : List Nat) (after : Nat)
    (hne : newTerms ≠ []) (hle : after ≤ u.offset + u.entries.length) :
    maybeLastIndex (truncateAndAppend u newTerms after) =
    some (after + newTerms.length - 1) := by
  have hlen : 0 < newTerms.length := by
    cases newTerms with | nil => exact absurd rfl hne | cons => simp
  by_cases h1 : after = u.offset + u.entries.length
  · -- Case 1: after = offset + len → append directly
    have hcase : truncateAndAppend u newTerms after =
        { u with entries := u.entries ++ newTerms } := by
      unfold truncateAndAppend; rw [if_pos h1]
    have hne2 : (u.entries ++ newTerms) ≠ [] := by
      cases newTerms with | nil => exact absurd rfl hne | cons => simp
    rw [hcase, maybeLastIndex_entries _ hne2, List.length_append]
    congr 1
    show u.offset + (u.entries.length + newTerms.length) - 1 = after + newTerms.length - 1
    omega
  · by_cases h2 : after ≤ u.offset
    · -- Case 2: after ≤ offset → replace entries and set offset = after
      have hcase : truncateAndAppend u newTerms after =
          { u with offset := after, entries := newTerms } := by
        unfold truncateAndAppend; rw [if_neg h1, if_pos h2]
      rw [hcase, maybeLastIndex_entries _ hne]
    · -- Case 3: offset < after < offset + len → truncate then append
      have hgt : u.offset < after := Nat.lt_of_not_le h2
      have hlt : after < u.offset + u.entries.length := Nat.lt_of_le_of_ne hle h1
      have hd : after - u.offset ≤ u.entries.length := by omega
      have hne3 : u.entries.take (after - u.offset) ++ newTerms ≠ [] := by
        cases newTerms with | nil => exact absurd rfl hne | cons => simp
      have hcase : truncateAndAppend u newTerms after =
          { u with entries := u.entries.take (after - u.offset) ++ newTerms } := by
        unfold truncateAndAppend; rw [if_neg h1, if_neg h2]
      rw [hcase, maybeLastIndex_entries _ hne3, List.length_append, List.length_take,
          Nat.min_eq_left hd]
      congr 1
      show u.offset + (after - u.offset + newTerms.length) - 1 = after + newTerms.length - 1
      omega

