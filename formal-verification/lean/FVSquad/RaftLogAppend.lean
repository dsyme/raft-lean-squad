-- Stable storage has entries [(index=1,term=1),(index=2,term=2)], committed=0.
-- Unstable is empty at offset=3 (= stable.last_index + 1).
private def exLog : RaftLog :=
  { committed := 0, stableLastIdx := 2,
    unstable := { offset := 3, entries := [], snapshot := none } }

-- No entries: returns last_index = 2 (stable)
#eval (raftLogAppend exLog []).2                            -- expected: 2

-- Append [(3,2)]: last_index becomes 3
#eval (raftLogAppend exLog [(3, 2)]).2                      -- expected: 3

-- Overwrite from index 1 with [(1,2)]: last_index becomes 1
-- (unstable now covers index 1 onwards, replacing stable view at that index)
#eval (raftLogAppend exLog [(1, 2)]).2                      -- expected: 1

-- Overwrite from index 2 with [(2,3),(3,3)]: last_index becomes 3
#eval (raftLogAppend exLog [(2, 3), (3, 3)]).2              -- expected: 3

