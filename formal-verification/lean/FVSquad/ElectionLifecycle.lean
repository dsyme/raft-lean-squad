/-! ## ElectionEpoch: bundles election + broadcast + well-formedness -/

/-- An `ElectionEpoch` represents a complete Raft election epoch:
    a leader wins an election, then broadcasts AppendEntries to all voters.

    This structure bundles all conditions needed to derive `hqc_preserved`
    unconditionally from EBC6, making `RaftReachable.step` fully concrete.

    **Parameters**:
    - `E`: entry type
    - `lead`: the elected leader node ID
    - `voters`: the voter list (`hd :: tl`)
    - `cs_pre`: cluster state before the broadcast
    - `cs_post`: cluster state after the full broadcast -/
structure ElectionEpoch (E : Type) [DecidableEq E]
    (lead : Nat) (hd : Nat) (tl : List Nat)
    (cs_pre cs_post : ClusterState E) where
  /-- The leader won the election in some term. -/
  record : VoteRecord
  term : Nat
  hwin : wonInTerm (hd :: tl) record term lead = true
  /-- Voter log identifiers (capturing each voter's log freshness at vote time). -/
  voterLog : Nat → LogId
  /-- Candidate last term/index functions for vote-record consistency. -/
  candLastTerm : Nat → Nat
  candLastIndex : Nat → Nat
  /-- The vote record is consistent with the vote-granting rules. -/
  hconsist : VoteRecordConsistency record voterLog candLastTerm candLastIndex
  /-- The broadcast sequence from `cs_pre` to `cs_post`. -/
  hseq : BroadcastSeq E lead (fun w => (voterLog w).index) (hd :: tl) cs_pre cs_post
  /-- Leader is not in the voter list (leader doesn't send AE to itself). -/
  hlead_not_in : lead ∉ (hd :: tl)
  /-- Non-voter log agreement (typically vacuous for complete voter lists). -/
  hnv_hae : ∀ w, w ∉ (hd :: tl) →
      ∀ k, k ≤ (voterLog w).index →
      cs_post.logs w k = cs_post.logs lead k
  /-- Log-none above voter index. -/
  hlog_none : ∀ w k, k > (voterLog w).index → cs_post.logs w k = none
  /-- Leader log monotonicity (no gaps above). -/
  hcand_mono : ∀ j k, j ≤ k → cs_post.logs lead k = none →
      cs_post.logs lead j = none
  /-- Voter index bounds entries. -/
  hvoter_idx : ∀ w k e, w ∈ (hd :: tl) → cs_post.logs w k = some e →
      k ≤ (voterLog w).index
  /-- The voter list of cs_post matches hd :: tl. -/
  hvoters_eq : cs_post.voters = hd :: tl

/-! ## EL1: hqc_preserved derived unconditionally from ElectionEpoch -/

/-- **EL1** — Given an `ElectionEpoch` and a subsequent `ValidAEStep` from `cs_post`,
    the `hqc_preserved` condition holds unconditionally.

    **Proof**: direct application of EBC6 (`broadcastSeq_hqc_preserved`) using the
    bundled epoch fields. -/
theorem electionEpoch_hqc_preserved {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post cs_next : ClusterState E}
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    {v_next : Nat} {msg_next : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs_post lead v_next msg_next cs_next) :
    ∀ k e, isQuorumCommitted cs_post.voters cs_post.logs k e →
           isQuorumCommitted cs_next.voters cs_next.logs k e :=
  broadcastSeq_hqc_preserved lead epoch.voterLog hd tl cs_pre cs_post
    epoch.hseq epoch.hlead_not_in hstep epoch.hvoters_eq
    epoch.record epoch.term epoch.candLastTerm epoch.candLastIndex
    epoch.hwin epoch.hnv_hae epoch.hlog_none epoch.hcand_mono
    epoch.hconsist epoch.hvoter_idx

/-! ## EL2: ValidAEStep after ElectionEpoch → RaftReachable -/

/-- **EL2** — A `ValidAEStep` from the post-broadcast state of an `ElectionEpoch`
    produces a `RaftReachable` state, provided the pre-broadcast state was reachable.

    **Proof**: The `ValidAEStep` provides `hlogs'`, `hno_overwrite`, `hcommitted_mono`,
    `hnew_cert` directly from its fields. The `hqc_preserved` comes from EL1. -/
theorem electionEpoch_validAEStep_raftReachable {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post cs_next : ClusterState E}
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    (hreach_post : RaftReachable cs_post)
    {v_next : Nat} {msg_next : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs_post lead v_next msg_next cs_next) :
    RaftReachable cs_next :=
  RaftReachable.step hreach_post
    hstep.hvoters.symm
    v_next
    hstep.hlogs'_other
    (fun k hk => by
      have h_le : cs_post.committed v_next ≤ msg_next.prevLogIndex := hstep.h_committed_le_prev
      have hkp : k ≤ msg_next.prevLogIndex := Nat.le_trans hk h_le
      rw [hstep.hlogs'_v]
      exact applyAE_preserves_prefix E (cs_post.logs v_next) msg_next k hkp)
    (electionEpoch_hqc_preserved epoch hstep)
    hstep.hcommitted_mono
    hstep.hnew_cert

/-! ## EL3: Post-epoch ValidAEStep → isClusterSafe -/

/-- **EL3** — Full safety: a `ValidAEStep` from the post-broadcast state of an
    `ElectionEpoch` yields a cluster-safe state.

    **Proof**: EL2 gives `RaftReachable cs_next`; RT2 (`raftReachable_safe`) closes. -/
theorem electionEpoch_full_safety {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post cs_next : ClusterState E}
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    (hreach_post : RaftReachable cs_post)
    {v_next : Nat} {msg_next : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs_post lead v_next msg_next cs_next)
    (hvoters_next : cs_next.voters = hd :: tl) :
    isClusterSafe cs_next :=
  raftReachable_safe hd tl cs_next hvoters_next
    (electionEpoch_validAEStep_raftReachable epoch hreach_post hstep)

/-! ## EL4: ElectionEpoch from initialCluster is valid -/

/-- **EL4** — An `ElectionEpoch` whose `cs_pre` is `initialCluster voters` produces
    a `RaftReachable` post-broadcast state (via BL3).

    **Significance**: this is the simplest concrete instantiation — start from the
    initial cluster, elect a leader, broadcast. -/
theorem electionEpoch_from_init {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_post : ClusterState E}
    (epoch : ElectionEpoch E lead hd tl (initialCluster (hd :: tl)) cs_post) :
    RaftReachable cs_post :=
  raftReachable_from_init_broadcast E lead (fun w => (epoch.voterLog w).index)
    (hd :: tl) cs_post epoch.hseq

/-! ## EL5: Post-broadcast state of any ElectionEpoch is RaftReachable -/

/-- **EL5** — If `cs_pre` is `RaftReachable`, then `cs_post` (after the broadcast)
    is also `RaftReachable`.

    **Proof**: BL2 (`raftReachable_after_broadcast`). -/
theorem electionEpoch_reachable {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post : ClusterState E}
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    (hreach_pre : RaftReachable cs_pre) :
    RaftReachable cs_post :=
  raftReachable_after_broadcast E lead (fun w => (epoch.voterLog w).index)
    (hd :: tl) cs_pre cs_post hreach_pre epoch.hseq

/-! ## EL6: Complete composition — election + broadcast + step → RaftReachable -/

/-- **EL6** — The full protocol lifecycle: given a `RaftReachable` state, an
    `ElectionEpoch` (election + broadcast), and a subsequent `ValidAEStep`,
    the resulting state is `RaftReachable`.

    **Chain**: EL5 (pre → post reachable) → EL2 (post + step → next reachable). -/
theorem fullProtocolStep_raftReachable {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post cs_next : ClusterState E}
    (hreach_pre : RaftReachable cs_pre)
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    {v_next : Nat} {msg_next : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs_post lead v_next msg_next cs_next) :
    RaftReachable cs_next :=
  electionEpoch_validAEStep_raftReachable epoch
    (electionEpoch_reachable epoch hreach_pre) hstep

/-! ## EL7: Complete composition — election + broadcast + step → isClusterSafe -/

/-- **EL7** — Safety end-to-end: given a `RaftReachable` state, an `ElectionEpoch`,
    and a subsequent `ValidAEStep`, the resulting state is cluster-safe.

    **Chain**: EL6 (→ RaftReachable) → RT2 (→ isClusterSafe).

    **Significance**: this is the **top-level safety theorem for a full Raft epoch**.
    No abstract axioms remain — every hypothesis of `RaftReachable.step` is discharged
    from concrete protocol conditions. -/
theorem fullProtocolStep_safe {E : Type} [DecidableEq E]
    {lead hd : Nat} {tl : List Nat}
    {cs_pre cs_post cs_next : ClusterState E}
    (hreach_pre : RaftReachable cs_pre)
    (epoch : ElectionEpoch E lead hd tl cs_pre cs_post)
    {v_next : Nat} {msg_next : AppendEntriesMsg E}
    (hstep : ValidAEStep E cs_post lead v_next msg_next cs_next)
    (hvoters_next : cs_next.voters = hd :: tl) :
    isClusterSafe cs_next :=
  raftReachable_safe hd tl cs_next hvoters_next
    (fullProtocolStep_raftReachable hreach_pre epoch hstep)

end FVSquad.ElectionLifecycle
