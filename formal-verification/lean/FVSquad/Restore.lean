namespace FVSquad.Restore

/-! ## State Model -/

/-- Simplified model of the unstable log segment.
    Only captures offset and entry count (entries are cleared on restore). -/
structure UnstableState where
  offset : Nat
  entryCount : Nat
  hasSnapshot : Bool
  deriving Repr, DecidableEq

/-- Simplified model of the RaftLog state relevant to `restore`. -/
structure RaftLogState where
  committed : Nat
  persisted : Nat
  applied : Nat
  unstable : UnstableState
  deriving Repr, DecidableEq

/-- The well-formedness invariant for a RaftLog: `applied в‰¤ persisted в‰¤ committed`. -/
def RaftLogState.wellFormed (s : RaftLogState) : Prop :=
  s.applied в‰¤ s.persisted в€§ s.persisted в‰¤ s.committed

/-! ## Restore Operation -/

/-- Model of `Unstable::restore`: clears entries, sets offset to index+1, stores snapshot. -/
def unstableRestore (snapshotIndex : Nat) : UnstableState :=
  { offset := snapshotIndex + 1, entryCount := 0, hasSnapshot := true }

/-- Model of `RaftLog::restore(snapshot)`.

    Precondition: `snapshotIndex в‰Ґ s.committed` (the Rust code asserts this).

    Steps:
    1. If `persisted > committed`, clamp persisted to committed
    2. Set committed to snapshotIndex
    3. Call unstableRestore on the unstable segment -/
def restore (s : RaftLogState) (snapshotIndex : Nat) : RaftLogState :=
  let persisted' := if s.persisted > s.committed then s.committed else s.persisted
  { committed := snapshotIndex,
    persisted := persisted',
    applied := s.applied,
    unstable := unstableRestore snapshotIndex }

/-! ## Theorems -/

/-- **RST1**: After restore, committed equals the snapshot index. -/
theorem restore_committed (s : RaftLogState) (idx : Nat) :
    (restore s idx).committed = idx := by
  simp [restore]

/-- **RST2**: After restore, `persisted в‰¤ committed`. -/
theorem restore_persisted_le_committed (s : RaftLogState) (idx : Nat)
    (hpre : idx в‰Ґ s.committed) :
    (restore s idx).persisted в‰¤ (restore s idx).committed := by
  simp [restore]
  split <;> omega

/-- **RST3**: Restore does not decrease committed. -/
theorem restore_committed_advances (s : RaftLogState) (idx : Nat)
    (hpre : idx в‰Ґ s.committed) :
    (restore s idx).committed в‰Ґ s.committed := by
  simp [restore]; omega

/-- **RST4**: Persisted is clamped to `min(old_persisted, old_committed)`. -/
theorem restore_persisted_clamp (s : RaftLogState) (idx : Nat) :
    (restore s idx).persisted = min s.persisted s.committed := by
  simp [restore]
  split <;> omega

/-- **RST5**: After restore, unstable offset = snapshot_index + 1. -/
theorem restore_unstable_offset (s : RaftLogState) (idx : Nat) :
    (restore s idx).unstable.offset = idx + 1 := by
  simp [restore, unstableRestore]

/-- **RST6**: After restore, unstable entries are cleared (count = 0). -/
theorem restore_unstable_entries_cleared (s : RaftLogState) (idx : Nat) :
    (restore s idx).unstable.entryCount = 0 := by
  simp [restore, unstableRestore]

/-- **RST7**: If the log was well-formed and `applied в‰¤ committed` before,
    the ordering invariant `applied в‰¤ persisted в‰¤ committed` holds after restore. -/
theorem restore_invariant_ordering (s : RaftLogState) (idx : Nat)
    (hwf : s.wellFormed) (hpre : idx в‰Ґ s.committed) :
    (restore s idx).wellFormed := by
  obtain вџЁhap, hpcвџ© := hwf
  simp [RaftLogState.wellFormed, restore]
  constructor
  В· split <;> omega
  В· split <;> omega

/-- **RST8**: Restoring at the current committed index does not change committed. -/
theorem restore_idempotent_committed (s : RaftLogState) :
    (restore s s.committed).committed = s.committed := by
  simp [restore]

end FVSquad.Restore
